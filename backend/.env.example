GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=
PORT=3001

# Separar varios orígenes mediante comas. Configurarlo en producción.
CORS_ORIGINS=http://localhost:5173,https://tu-frontend.example.com

# Límites operativos para lotes de hasta 10 documentos.
MAX_FILE_MB=150
GEMINI_INLINE_MAX_MB=20
GEMINI_PDF_MAX_MB=50
GEMINI_PDF_CHUNK_MB=40
MAX_CONCURRENT_AUDITS=3
AUDIT_QUEUE_TIMEOUT_MS=180000
GEMINI_TIMEOUT_MS=120000
CLIENT_CACHE_TTL_MS=60000
